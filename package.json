{
  "name": "clawd-strike-agent-sdk",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "contract:check": "node scripts/validate-sdk-contract.mjs",
    "smoke:no-context": "node examples/no-context-smoke.mjs",
    "agent:baseline": "node examples/baseline-loop.mjs",
    "agent:learn": "node examples/self-improving-runner.mjs",
    "test:unit": "node --test test/*.test.mjs",
    "ci:check": "pnpm contract:check && pnpm test:unit && node --check examples/no-context-smoke.mjs && node --check examples/baseline-loop.mjs && node --check examples/self-improving-runner.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dimitricritsinelis/clawd-strike-agent-sdk.git"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
